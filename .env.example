# ============================================================
# YouTube Cliper Automation – Environment Variables
# ============================================================

# Groq API Key (get yours at https://console.groq.com)
GROQ_API_KEY=gsk_your_api_key_here

# LLM Model to use (default: llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile

# Max clips to generate per video (default: 5)
AI_MAX_CLIPS=5

# Target clip duration range in seconds
AI_MIN_CLIP_DURATION=30
AI_MAX_CLIP_DURATION=60

# Caption settings
CAPTION_ENABLED=true
WHISPER_MODEL=base
